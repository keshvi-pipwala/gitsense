# ═══════════════════════════════════════════════════
# GitSense — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Application ──────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-to-a-random-64-char-string
FRONTEND_URL=http://localhost:3000

# ── GitHub ────────────────────────────────────────
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Webhook HMAC secret — set the same value in your
# GitHub repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── Google Gemini AI ──────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Database ──────────────────────────────────────
# Docker Compose sets this automatically.
# Override only if using an external database.
DATABASE_URL=postgresql://gitsense:gitsense@postgres:5432/gitsense

# ── Redis / Celery ────────────────────────────────
# Docker Compose sets this automatically.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Slack Notifications (optional) ───────────────
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Email Notifications (optional) ───────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
# For Gmail: generate app password at myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password
SMTP_FROM=GitSense <your@email.com>

# ── ChromaDB vector store ─────────────────────────
# Persist directory (mapped to Docker volume)
CHROMA_PERSIST_DIR=/data/chroma

# ── Monitoring thresholds ─────────────────────────
# Risk levels that trigger notifications: HIGH,CRITICAL
NOTIFY_RISK_LEVELS=HIGH,CRITICAL

# Days before an open PR is marked stale
STALE_PR_DAYS=7

# Hours between scheduled health checks
HEALTH_CHECK_INTERVAL_HOURS=6
